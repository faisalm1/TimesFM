# Alpaca — keys from https://app.alpaca.markets/ (Paper or Live)
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Optional: override market *data* host (default in code is data.alpaca.markets).
# Do not set this to https://api.alpaca.markets — that host is for trading, not historical bars.
# APCA_DATA_BASE_URL=https://data.alpaca.markets

# ── Daily email alerts (top 5 gap-up + gap-down, sent at 3:45 PM ET) ──
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=yourapp@gmail.com
ALERT_SMTP_PASSWORD=your-app-password
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_EMAIL_HOUR=15
# ALERT_EMAIL_MINUTE=45

# ── Scheduler overrides ──
# SCHEDULER_HOUR=16
# SCHEDULER_MINUTE=30
# SCHEDULER_DISABLE=false
